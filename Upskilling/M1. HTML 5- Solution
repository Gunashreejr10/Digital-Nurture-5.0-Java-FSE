    <script> 
        

// Exercise 5: form confirmation 
        function showConfirmation() { 
            document.getElementById("confirmOutput").textContent = "Registration submitted 
successfully!"; 
            return false; // prevent actual page reload for demo 
        } 
 
 
// Exercise 6: phone validation on blur 
        function validatePhone() { 
            var phone = document.getElementById("phone").value; 
            var errorBox = document.getElementById("phoneError"); 
            var isValid = /^[0-9]{10}$/.test(phone); 
            errorBox.textContent = isValid ? "" : "Enter a valid 10-digit phone number."; 
        } 
 
       
// Exercise 6: dropdown change shows fee 
        function showFee() { 
            var select = document.getElementById("eventType"); 
            var fee = select.options[select.selectedIndex].getAttribute("data-fee"); 
            document.getElementById("feeDisplay").textContent = fee ? "Fee: " + fee : ""; 
        } 
 
        // Exercise 6: click confirmation 
        function confirmClick() { 
            alert("Thanks! Your registration is being processed."); 
        } 
 
        // Exercise 6: double-click to enlarge image 
        function enlargeImage(img) { 
            img.style.width = img.style.width === "300px" ? "150px" : "300px"; 
        } 
 
        // Exercise 6: keyboard event to count characters 
        function countChars() { 
            var text = document.getElementById("message").value; 
            document.getElementById("charCount").textContent = text.length; 
        } 
 
        // Exercise 7: video ready event 
        function videoReady() { 
            document.getElementById("videoMsg").textContent = "Video ready to play."; 
        } 
 
        // Exercise 7: warn before leaving unfinished form 
        window.onbeforeunload = function () { 
            var name = document.getElementById("name").value; 
            if (name.trim() !== "") { 
                return "You have unsaved registration data. Are you sure you want to leave?"; 
            } 
        }; 
 
        // Exercise 8: localStorage preferences 
        function savePreference() { 
            var eventType = document.getElementById("eventType").value; 
            localStorage.setItem("preferredEvent", eventType); 
            sessionStorage.setItem("sessionEvent", eventType); 
            document.getElementById("prefMsg").textContent = "Preference saved: " + eventType; 
        } 
 
        function clearPreference() { 
            localStorage.removeItem("preferredEvent"); 
            sessionStorage.removeItem("sessionEvent"); 
            document.getElementById("prefMsg").textContent = "Preferences cleared."; 
        } 
 
        window.onload = function () { 
            var saved = localStorage.getItem("preferredEvent"); 
            if (saved) { 
                document.getElementById("eventType").value = saved; 
                showFee(); 
            } 
        }; 
  // Exercise 9: geolocation 
        function findLocation() { 
            var msg = document.getElementById("locationMsg"); 
            if (!navigator.geolocation) { 
                msg.textContent = "Geolocation is not supported by your browser."; 
                return; 
            } 
            var options = { enableHighAccuracy: true, timeout: 8000, maximumAge: 0 }; 
             
            navigator.geolocation.getCurrentPosition( 
                function (position) { 
                    msg.textContent = "You are at Lat: " + position.coords.latitude + ", Lng: " + 
position.coords.longitude; 
                }, 
                function (error) { 
                    if (error.code === error.PERMISSION_DENIED) { 
                        msg.textContent = "Permission denied. Please allow location access."; 
                    } else if (error.code === error.TIMEOUT) { 
                        msg.textContent = "Request timed out. Try again."; 
                    } else { 
                        msg.textContent = "Unable to fetch location."; 
                    } 
                }, 
                options 
            ); 
        } 
    </script> 
</body> 
</html> 
 
