8. Operator Precedence
Objective: Explore how Java evaluates expressions.
OperatorPrecedence.java
public class OperatorPrecedence {
    public static void main(String[] args) {
     
        int result = 10 + 5 * 2;
        System.out.println("10 + 5 * 2 = " + result);
        System.out.println("Java evaluates * before +, so it multiplies 5*2 first, then adds 10.");
        int result2 = (10 + 5) * 2;
        System.out.println("(10 + 5) * 2 = " + result2);
        int result3 = 20 / 4 + 3 * 2 - 1;
        System.out.println("20 / 4 + 3 * 2 - 1 = " + result3);
        System.out.println("Order: division and multiplication first (5 and 6), then left-to-right addition/subtraction: 5 + 6 - 1 = 10");
    }
}

