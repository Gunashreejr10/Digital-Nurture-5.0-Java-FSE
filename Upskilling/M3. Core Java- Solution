import java.lang.reflect.Method;
 
public class ReflectionExample {
 
    public static void main(String[] args) throws Exception {
        // load the Greeter class by name, without importing it directly
        Class<?> clazz = Class.forName("Greeter");
 
        // create an instance of it
        Object greeterInstance = clazz.getDeclaredConstructor().newInstance();
 
        // list all its methods
        Method[] methods = clazz.getDeclaredMethods();
        System.out.println("Methods found in Greeter:");
        for (Method m : methods) {
            System.out.println("- " + m.getName() + ", parameters: " + m.getParameterCount());
        }
 
        // now actually call sayHello() dynamically
        Method sayHello = clazz.getMethod("sayHello", String.class);
        sayHello.invoke(greeterInstance, "Reflection");
    }
}
 
class Greeter {
    public void sayHello(String name) {
        System.out.println("Hello, " + name + "! This method was called via reflection.");
    }
}

40. Virtual Threads (Java 21)
Objective: Use lightweight threads for scalable concurrency.
VirtualThreadsDemo.java
public class VirtualThreadsDemo {
    public static void main(String[] args) throws InterruptedException {
 
        // ----- Virtual threads (lightweight, Java 21+) -----
        long startVirtual = System.currentTimeMillis();
 
        Thread[] virtualThreads = new Thread[100_000];
        for (int i = 0; i < 100_000; i++) {
            int taskNumber = i;
            virtualThreads[i] = Thread.startVirtualThread(() -> {
                // keep the work tiny, we just want to see that 100k threads don't crash things
                if (taskNumber == 99_999) {
                    System.out.println("Last virtual thread finished!");
                }
            });
        }
        for (Thread t : virtualThreads) {
            t.join();
        }
 
        long endVirtual = System.currentTimeMillis();
        System.out.println("100,000 virtual threads took " + (endVirtual - startVirtual) + " ms");
 
        // ----- Traditional platform threads, much smaller number, they're expensive -----
        long startPlatform = System.currentTimeMillis();
 
        int platformCount = 1000; // don't try 100,000 of these, your OS will not thank you
        Thread[] platformThreads = new Thread[platformCount];
        for (int i = 0; i < platformCount; i++) {
            platformThreads[i] = new Thread(() -> {
                // empty task, just measuring thread creation overhead
            });
            platformThreads[i].start();
        }
        for (Thread t : platformThreads) {
            t.join();
        }
 
        long endPlatform = System.currentTimeMillis();
        System.out.println(platformCount + " platform threads took " + (endPlatform - startPlatform) + " ms");
    }
}

41. Executor Service and Callable
Objective: Use concurrency utilities.
ExecutorServiceDemo.java
import java.util.ArrayList;
import java.util.List;
import java.util.concurrent.Callable;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.Future;
 
public class ExecutorServiceDemo {
    public static void main(String[] args) throws Exception {
        ExecutorService executor = Executors.newFixedThreadPool(4);
 
        List<Callable<Integer>> tasks = new ArrayList<>();
        for (int i = 1; i <= 5; i++) {
            int number = i;
            tasks.add(() -> {
                // pretend this is some heavier calculation
                return number * number;
            });
        }
 
        List<Future<Integer>> futures = new ArrayList<>();
        for (Callable<Integer> task : tasks) {
            futures.add(executor.submit(task));
        }
 
        for (int i = 0; i < futures.size(); i++) {
            int result = futures.get(i).get(); // blocks until this task is done
            System.out.println("Task " + (i + 1) + " result: " + result);
        }
 
        executor.shutdown();
    }
}

