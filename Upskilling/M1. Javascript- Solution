11. Working with Forms 
document.querySelector("#registerForm").addEventListener("submit", function (e) { 
  e.preventDefault(); 
 
  const nameInput = document.querySelector("#name").value.trim(); 
  const emailInput = document.querySelector("#email").value.trim(); 
  const selectedEvent = document.querySelector("#eventSelect").value; 
  const errorBox = document.querySelector("#formError"); 
 
  errorBox.textContent = ""; 
 
  if (!nameInput || !emailInput) { 
    errorBox.textContent = "Name and email are required."; 
    return; 
  } 
 
  if (!emailInput.includes("@")) { 
    errorBox.textContent = "Please enter a valid email."; 
    return; 
  } 
 
  console.log(`Registering ${nameInput} (${emailInput}) for ${selectedEvent}`); 
}); 
 
12. AJAX & Fetch API 
function submitRegistration(userData) { 
  fetch("https://mockapi.example.com/register", { 
    method: "POST", 
    headers: { "Content-Type": "application/json" }, 
    body: JSON.stringify(userData) 
  }) 
    .then(response => { 
      if (!response.ok) throw new Error("Registration failed"); 
      return response.json(); 
    }) 
    .then(result => { 
      console.log("Success:", result); 
    }) 
    .catch(err => { 
      console.error("Error:", err.message); 
    }); 
} 
 
// Simulating a delayed server response 
function simulateDelayedResponse(userData) { 
  console.log("Sending registration..."); 
  setTimeout(() => { 
    console.log(`Registration for ${userData.name} completed`); 
  }, 2000); 
} 
 
13. Debugging and Testing 
Since this is a debugging task rather than code to run, here's how you'd actually approach it: 
● Open Chrome Dev Tools (F12) and check the Console tab first for red error messages — 
a silent failure usually still throws something there. 
● Go to the Network tab, submit the form, and click the request to /register. Check the 
Payload tab to confirm the data actually being sent matches what you expect. 
● Set a breakpoint inside the submit handler (click the line number in the Sources tab) and 
step through line by line, watching the Scope panel for variable values. 
● Add temporary logs at each step to narrow down where it breaks: 
document.querySelector("#registerForm").addEventListener("submit", function (e) { 
e.preventDefault(); 
console.log("Form submitted"); 
const nameInput = document.querySelector("#name").value; 
console.log("Name captured:", nameInput); 
const payload = { name: nameInput }; 
console.log("Payload ready:", payload); 
fetch("https://mockapi.example.com/register", { 
method: "POST", 
body: JSON.stringify(payload) 
}).then(res => console.log("Response status:", res.status)); 
}); 

