7. DOM Manipulation 
function renderEvents(eventList) { 
  const container = document.querySelector("#eventContainer"); 
  container.innerHTML = ""; 
 
  eventList.forEach(evt => { 
    const card = document.createElement("div"); 
    card.className = "event-card"; 
    card.innerHTML = ` 
      <h3>${evt.name}</h3> 
      <p>${evt.date} | Seats: ${evt.seats}</p> 
      <button class="register-btn" data-name="${evt.name}">Register</button> 
    `; 
    container.appendChild(card); 
  }); 
} 
 
renderEvents(eventArray); 
 
function updateSeatDisplay(eventName, newSeatCount) { 
  const cards = document.querySelectorAll(".event-card"); 
  cards.forEach(card => { 
    if (card.querySelector("h3").textContent === eventName) { 
      card.querySelector("p").textContent = `Seats: ${newSeatCount}`; 
    } 
  }); 
} 
 
8. Event Handling 
document.querySelector("#eventContainer").addEventListener("click", function (e) { 
  if (e.target.classList.contains("register-btn")) { 
    const name = e.target.dataset.name; 
    const evt = eventArray.find(ev => ev.name === name); 
    console.log(registerUser(evt, "Guest User")); 
    renderEvents(eventArray); 
  } 
}); 
 
document.querySelector("#categoryFilter").addEventListener("change", function (e) { 
  const category = e.target.value; 
  const filtered = category === "all" ? eventArray : filterEventsByCategory(eventArray, category); 
  renderEvents(filtered); 
}); 
 
document.querySelector("#searchBox").addEventListener("keydown", function (e) { 
  const query = e.target.value.toLowerCase(); 
  const filtered = eventArray.filter(evt => evt.name.toLowerCase().includes(query)); 
  renderEvents(filtered); 
}); 
 
9. Async JS, Promises, Async/Await 
function fetchEventsFromAPI() { 
  return fetch("https://mockapi.example.com/events") 
    .then(response => response.json()) 
    .then(data => { 
      console.log("Events loaded:", data); 
      return data; 
    }) 
    .catch(err => { 
      console.error("Failed to load events:", err); 
    }); 
} 
 
async function loadEventsAsync() { 
  const spinner = document.createElement("p"); 
  spinner.textContent = "Loading events..."; 
  document.body.appendChild(spinner); 
 
  try { 
    const response = await fetch("https://mockapi.example.com/events"); 
    const data = await response.json(); 
    renderEvents(data); 
  } catch (err) { 
    console.error("Error loading events:", err); 
  } finally { 
    spinner.remove(); 
  } 
} 
 
