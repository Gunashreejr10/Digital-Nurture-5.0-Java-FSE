3. Conditionals, Loops, and Error Handling 
const events = [ 
{ name: "Baking Workshop", date: "2026-07-15", seats: 10 }, 
{ name: "Rock Concert", date: "2026-06-01", seats: 0 }, 
{ name: "Yoga in the Park", date: "2026-08-02", seats: 5 } 
]; 
function showUpcomingEvents(eventList) { 
  const today = new Date(); 
 
  eventList.forEach(function (evt) { 
    const eventDate = new Date(evt.date); 
 
    if (eventDate < today) { 
      console.log(`${evt.name} has already happened - skipping`); 
      return; 
    } 
 
    if (evt.seats <= 0) { 
      console.log(`${evt.name} is full - skipping`); 
      return; 
    } 
 
    console.log(`${evt.name} on ${evt.date} - ${evt.seats} seats left`); 
  }); 
} 
 
showUpcomingEvents(events); 
 
function registerUserSafely(evt) { 
  try { 
    if (!evt) throw new Error("Event not found"); 
    if (evt.seats <= 0) throw new Error("No seats available"); 
    evt.seats--; 
    console.log(`Registered for ${evt.name}`); 
  } catch (err) { 
    console.error("Registration failed:", err.message); 
  } 
} 
 

