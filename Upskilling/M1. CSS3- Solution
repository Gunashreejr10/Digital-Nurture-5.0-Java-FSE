10. Responsive Web Design with Media Queries 
/* Base (desktop-first) styles */ 
nav ul li { 
display: inline-block; 
} 
.eventCard img { 
width: 100%; 
max-width: 400px; 
} 
.hero { 
height: 60vh; 
width: 100%; 
} 
/* Media query for screens smaller than 768px */ 
@media (max-width: 768px) { 
nav ul { 
    display: flex; 
    flex-direction: column; 
  } 
 
  nav ul li { 
    display: block; 
    width: 100%; 
  } 
 
  .eventCard img { 
    max-width: 100%; 
  } 
 
  h1 { 
    font-size: 24px; 
  } 
 
  p { 
    font-size: 14px; 
  } 
} 
