6. Link and List Styling 
/* Pseudo-classes for links */ 
a:link { 
  color: #007BFF; 
  text-decoration: none; 
} 
 
a:visited { 
  color: #6c757d; 
} 
 
a:hover { 
  color: #0056b3; 
  text-decoration: underline; 
} 
 
a:active { 
  color: #003d80; 
} 
 
/* Navigation list - remove bullets */ 
nav ul { 
  list-style-type: none; 
  list-style-position: outside; 
  margin: 0; 
  padding: 0; 
} 
 
nav ul li { 
  display: inline-block; 
  padding: 10px 15px; 
  margin-right: 5px; 
} 
 
/* General list styling */ 
.event-list li { 
  list-style-type: square; 
  padding: 5px 0; 
  margin-left: 20px; 
} 


